rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: lessons
    // Fields:
    //   - title: string (required, 1-200 chars)
    //   - content: string (required, 1-5000 chars)
    //   - date: string (required, ISO format)
    //   - adminId: string (required, matches auth.uid)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidLesson(data) {
      return data.keys().hasAll(['title', 'content', 'date', 'adminId']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 5000 &&
             data.date is string &&
             data.adminId == request.auth.uid;
    }

    match /lessons/{lessonId} {
      // Teachers and Admins can read all lessons if authenticated
      allow read: if isAuthenticated();
      
      // Only authenticated users can create lessons (Admin role assumed)
      allow create: if isAuthenticated() && isValidLesson(request.resource.data);
      
      // Only the creator can update or delete
      allow update: if isAuthenticated() && request.auth.uid == resource.data.adminId && isValidLesson(request.resource.data);
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.adminId;
    }

    // Allow reading a specific test document for connection verification
    match /connection_test/status {
      allow read: if true;
    }
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
