{
  "entities": {
    "Lesson": {
      "title": "Lesson",
      "description": "Educational lesson data entered by the admin.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The name of the lesson."
        },
        "content": {
          "type": "string",
          "description": "The content of the lesson."
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "The date the lesson was created or scheduled."
        },
        "adminId": {
          "type": "string",
          "description": "The UID of the admin who created the lesson."
        }
      },
      "required": ["title", "content", "date", "adminId"]
    }
  },
  "firestore": {
    "lessons": {
      "schema": "Lesson",
      "description": "Collection of lessons shared between admin and teacher."
    },
    "connection_test": {
      "schema": {
        "type": "object",
        "properties": {
          "status": { "type": "string" }
        }
      },
      "description": "Used for verifying database connectivity."
    }
  }
}
